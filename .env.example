# Application Configuration
NODE_ENV=development
PORT=3000

# Database Configuration (Turso)
# Get these from: https://turso.tech
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# JWT Token Configuration - SECURITY CRITICAL
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 bytes (256 bits) for HS256/HS512 algorithms
# Use DIFFERENT secrets for development and production
# MUST be base64 or hex encoded 32+ byte strings
ACCESS_TOKEN_SECRET=your-256-bit-access-token-secret-key-here-change-in-production
REFRESH_TOKEN_SECRET=your-256-bit-refresh-token-secret-key-here-change-in-production

# JWT Legacy Configuration (deprecated, kept for compatibility)
JWT_SECRET=your-256-bit-jwt-secret-key-here-change-in-production
JWT_REFRESH_SECRET=your-256-bit-jwt-refresh-secret-key-here-change-in-production

# Rate Limiting & Brute Force Protection
# Maximum login attempts before IP lockout (per RATE_LIMIT_WINDOW_MINUTES)
RATE_LIMIT_ATTEMPTS=5
# Time window for rate limit (in minutes)
RATE_LIMIT_WINDOW_MINUTES=15
# Maximum failed login attempts before account lockout
MAX_FAILED_ATTEMPTS=3
# Duration of account lockout when max attempts exceeded (in minutes)
ACCOUNT_LOCK_DURATION_MINUTES=15

# Token Expiration Times
# Access token lifetime (format: '15m', '1h', etc.) - short-lived for security
ACCESS_TOKEN_EXPIRY=15m
# Refresh token lifetime (format: '30d', '7d', etc.) - long-lived but revocable
REFRESH_TOKEN_EXPIRY=30d

# Password Hashing
# Bcrypt salt rounds (higher = more secure but slower, 10-14 recommended)
BCRYPT_ROUNDS=12

# External API Keys
# IFSC Lookup: https://rapidapi.com/
RAPIDAPI_KEY=your-rapidapi-key-for-ifsc-lookup

# Email Configuration (Optional - for security notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Security Configuration
CSP_ENABLED=true
XSS_PROTECTION=true
# HSTS (HTTP Strict Transport Security) - enable in production only
# HSTS_MAX_AGE=31536000
# HSTS_INCLUDE_SUBDOMAINS=true

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# Development Features
ENABLE_SWAGGER=false
ENABLE_CORS=true

# Vercel Configuration (Auto-set by Vercel)
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=your-app.vercel.app

# ============================================================================
# SECURITY NOTES FOR ADMINISTRATORS
# ============================================================================
# 1. Generate Secure Secrets:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. JWT Algorithms:
#    - ACCESS_TOKEN: HS256 (HMAC SHA-256) - symmetric key authentication
#    - REFRESH_TOKEN: HS512 (HMAC SHA-512) - higher security for long-lived tokens
#
# 3. Token Storage:
#    - Tokens stored as HTTP-only cookies (not accessible via JavaScript)
#    - Refresh tokens hashed in database (SHA-256)
#    - Revocation tracking via TokenBlacklist collection
#
# 4. Rate Limiting:
#    - IP-based rate limiting on login (5 attempts per 15 minutes)
#    - Account-based lockout (3 failed attempts = 15 min lock)
#    - Automatic reset on successful login
#
# 5. Session Management:
#    - Device fingerprinting for multi-device support
#    - Token family tracking for refresh chain security
#    - Suspicious activity detection and logging
#
# 6. Production Checklist:
#    - [ ] Generate unique secrets for production
#    - [ ] Store secrets in secure configuration management (e.g., AWS Secrets Manager)
#    - [ ] Enable HSTS headers
#    - [ ] Use HTTPS/TLS only
#    - [ ] Enable CSP headers
#    - [ ] Configure email notifications for suspicious activity
#    - [ ] Set up monitoring for failed login attempts
#    - [ ] Regular audit logs review
# ============================================================================

